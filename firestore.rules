// firestore.rules — Copy into Firebase Console → Firestore → Rules
// Locks down all collections; only server Admin SDK can write privileged fields.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.approvedPurchases == 0
                    && request.resource.data.rewardUnlocked == false
                    && request.resource.data.rewardRedeemed == false;

      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.approvedPurchases == resource.data.approvedPurchases
                    && request.resource.data.rewardUnlocked == resource.data.rewardUnlocked
                    && request.resource.data.rewardRedeemed == resource.data.rewardRedeemed;
    }

    match /uploads/{uploadId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /rewards/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rewardUnlocked == true
                    && request.resource.data.redeemed == false;
      allow update, delete: if false;
    }

    match /otps/{otpId} {
      allow read, write: if false;
    }
  }
}
